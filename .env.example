# === Backend (girdap-2026-team-2/backend) ===
# API portu — varsayılan 4000
PORT=4000

# İleride Voice / modül yanıtlarında Google Gemini kullanacaksanız (şu an mock).
# Google AI Studio: https://aistudio.google.com/apikey
# Kod tarafında tek isim tercih edin; örnek implementasyonda ikisinden biri okunabilir.
GEMINI_API_KEY=
# Alternatif isim (bazı SDK örnekleri):
GOOGLE_GENERATIVE_AI_API_KEY=

# === Frontend (girdap-2026-team-2/frontend) ===
# Backend kök URL — sondaki / olmadan
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
